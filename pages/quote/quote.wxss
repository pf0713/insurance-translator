.container { padding: 32rpx; padding-bottom: 120rpx; }

.header { text-align: center; padding: 32rpx 0 20rpx; }
.header-title { font-size: 40rpx; font-weight: 700; color: #1a1a2e; }
.header-sub { font-size: 26rpx; color: #999; margin-top: 8rpx; }

/* ── 导航 ── */
.page-nav { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.page-nav-btn { flex: 1; text-align: center; padding: 16rpx 0;
  background: #fff; border-radius: 14rpx; font-size: 24rpx; color: #666;
  border: 2rpx solid transparent; }
.page-nav-btn--on { background: #2c3e50; color: #fff; font-weight: 600; }

/* ── 卡片 ── */
.policy-card { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 18rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04); }
.policy-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.policy-label { font-size: 28rpx; font-weight: 700; color: #2c3e50; padding: 6rpx 20rpx;
  background: #f0f4f8; border-radius: 10rpx; }
.policy-del { font-size: 28rpx; padding: 4rpx 12rpx; }

.input-tabs { display: flex; gap: 10rpx; margin-bottom: 12rpx; }
.tab { flex: 1; text-align: center; padding: 14rpx 0; background: #f7f5f1;
  border-radius: 10rpx; font-size: 22rpx; color: #888; }
.tab--on { background: #2c3e50; color: #fff; font-weight: 600; }

.cmp-input { width: 100%; min-height: 140rpx; font-size: 26rpx; line-height: 1.8;
  background: #fafaf8; border-radius: 12rpx; padding: 20rpx; margin-bottom: 12rpx; }
.cmp-upload { display: flex; align-items: center; justify-content: center;
  background: #fafaf8; border: 2rpx dashed #ddd; border-radius: 14rpx;
  min-height: 100rpx; margin-bottom: 12rpx; padding: 24rpx; }
.cmp-upload-text { font-size: 28rpx; color: #999; }
.cmp-preview { width: 100%; border-radius: 8rpx; }
.cmp-file-name { font-size: 26rpx; color: #333; }

.cmp-company { width: 100%; height: 72rpx; background: #fafaf8; border-radius: 36rpx;
  padding: 0 28rpx; font-size: 26rpx; color: #333; margin-bottom: 14rpx; }

.add-btn { text-align: center; padding: 28rpx; background: #fff; border-radius: 16rpx;
  border: 2rpx dashed #c0c0c0; color: #888; font-size: 28rpx; margin-bottom: 28rpx; }
.add-btn:active { background: #fafaf8; border-color: #b8860b; color: #b8860b; }

.main-btn { width: 100%; height: 96rpx; line-height: 96rpx; background: #2c3e50;
  color: #fff; font-size: 32rpx; font-weight: 600; border-radius: 48rpx;
  margin-bottom: 36rpx; letter-spacing: 2rpx; }
.main-btn:active { opacity: 0.85; }
.main-btn[disabled] { background: #c0c0c0; }

.loading-box { text-align: center; padding: 60rpx 0; color: #999; font-size: 26rpx; }
.spinner { width: 52rpx; height: 52rpx; border: 4rpx solid #eee; border-top-color: #b8860b;
  border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 20rpx; }
@keyframes spin { to { transform: rotate(360deg); } }

.result-box { margin-top: 28rpx; }
.result-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 18rpx; }
.result-content { background: #fff; border-radius: 20rpx; padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  font-size: 26rpx; line-height: 1.9; color: #444; white-space: pre-wrap; word-break: break-all; }

.empty { text-align: center; padding: 80rpx 40rpx; color: #aaa; font-size: 26rpx; line-height: 1.8; }
