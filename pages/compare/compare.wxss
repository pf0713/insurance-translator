.container { padding: 32rpx; padding-bottom: 120rpx; }

.header { text-align: center; padding: 32rpx 0 16rpx; }
.header-title { font-size: 40rpx; font-weight: 700; color: #1a1a2e; }
.header-sub { font-size: 26rpx; color: #999; margin-top: 8rpx; }

/* ── 导航 ── */
.page-nav { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.page-nav-btn { flex: 1; text-align: center; padding: 16rpx 0;
  background: #fff; border-radius: 14rpx; font-size: 24rpx; color: #666;
  border: 2rpx solid transparent; }
.page-nav-btn--on { background: #2c3e50; color: #fff; font-weight: 600; }

/* ── 输入卡片 ── */
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 22rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04); }
.card-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }

.input-tabs { display: flex; gap: 10rpx; margin-bottom: 16rpx; }
.tab { flex: 1; text-align: center; padding: 14rpx 0; background: #f7f5f1;
  border-radius: 10rpx; font-size: 22rpx; color: #888; }
.tab--on { background: #2c3e50; color: #fff; font-weight: 600; }

.text-input { width: 100%; min-height: 280rpx; font-size: 28rpx; line-height: 1.9;
  color: #333; margin-bottom: 16rpx; }

.upload-box { display: flex; align-items: center; justify-content: center;
  background: #fafaf8; border: 2rpx dashed #ddd; border-radius: 14rpx;
  min-height: 160rpx; margin-bottom: 16rpx; padding: 40rpx 20rpx; }
.upload-text { font-size: 28rpx; color: #999; }
.preview-img { width: 100%; border-radius: 8rpx; }

.main-btn { width: 100%; height: 96rpx; line-height: 96rpx; background: #2c3e50;
  color: #fff; font-size: 32rpx; font-weight: 600; border-radius: 48rpx; }
.main-btn:active { opacity: 0.85; }
.main-btn[disabled] { background: #c0c0c0; }

/* ── 对话区 ── */
.chat-list { padding-bottom: 20rpx; }
.chat-msg { display: flex; margin-bottom: 28rpx; }
.chat-expert { flex-direction: row; }
.chat-user { flex-direction: row-reverse; }

.chat-avatar { width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center;
  font-size: 34rpx; margin-right: 12rpx; flex-shrink: 0; }

.chat-bubble { max-width: 85%; padding: 20rpx 28rpx; border-radius: 20rpx;
  font-size: 28rpx; line-height: 1.8; white-space: pre-wrap; word-break: break-all; }
.chat-bubble--expert { background: #fff; color: #333;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); border-top-left-radius: 6rpx; }
.chat-bubble--user { background: #2c3e50; color: #fff; border-top-right-radius: 6rpx; }
.chat-bubble--loading { color: #999; display: flex; align-items: center; gap: 10rpx; }

/* ── 底部输入 ── */
.chat-input-bar { display: flex; gap: 16rpx; padding: 20rpx 0;
  position: fixed; bottom: 0; left: 0; right: 0; background: #f7f5f1;
  padding: 18rpx 32rpx; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04); }
.chat-input { flex: 1; height: 72rpx; background: #fff; border-radius: 36rpx;
  padding: 0 28rpx; font-size: 26rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.chat-send { width: 110rpx; height: 72rpx; line-height: 72rpx; background: #2c3e50;
  color: #fff; font-size: 26rpx; border-radius: 36rpx; text-align: center; }
.chat-send[disabled] { background: #c0c0c0; }

/* ── 加载 ── */
.spinner { width: 52rpx; height: 52rpx; border: 4rpx solid #eee; border-top-color: #b8860b;
  border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 20rpx; }
.spinner--small { width: 28rpx; height: 28rpx; border-width: 3rpx; margin: 0; }
@keyframes spin { to { transform: rotate(360deg); } }

.empty { text-align: center; padding: 80rpx 40rpx; color: #aaa; font-size: 26rpx; line-height: 1.8; }
